PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/goabroadafrica
JWT_SECRET=replace_with_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d
 
# AWS S3 for file uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=goabroadafrica-uploads
 
# Email (use SendGrid or Gmail SMTP)
EMAIL_FROM=noreply@goabroadafrica.com
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key
 
# Stripe payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
 
# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
 
